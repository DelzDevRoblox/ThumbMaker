							<Item class="TextLabel" referent="RBX4D94C7C43C2040CF926F36EE0F36EA7D">
								<Properties>
									<Font name="FontFace">
										<Family><url>rbxasset://fonts/families/Ubuntu.json</url></Family>
										<Weight>400</Weight>
										<Style>Normal</Style>
									</Font>
